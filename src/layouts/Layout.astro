---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'OnO INTERNATIONALは、動画制作・AI構築・フリーダイビング映像サービスで企業さまをコンサルティングする会社です。' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="pkIaklxAVA2f3rqYO4OPTXvL6R1nBBD_wAgOkJ46z1Y" />
    <!-- OGP -->
    <meta property="og:title" content={`${title} | OnO INTERNATIONAL`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://ono-international.com/logo%20ono.png" />
    <meta property="og:site_name" content="OnO INTERNATIONAL" />
    <meta property="og:locale" content="ja_JP" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | OnO INTERNATIONAL`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://ono-international.com/logo%20ono.png" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href={`${base}logo.png`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title} | OnO INTERNATIONAL</title>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-GLW20WQESK"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-GLW20WQESK');
    </script>
  </head>
  <body>
    <!-- Header -->
    <header id="header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
      <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
        <!-- Logo -->
        <a href={base} class="flex items-center gap-3 group">
          <img src={`${base}logo.png`} alt="OnO International" class="h-10 w-auto" />
          <span class="text-white font-bold text-lg tracking-wide">OnO <span class="gradient-text">INTERNATIONAL</span></span>
        </a>

        <!-- Nav Desktop -->
        <nav class="hidden md:flex items-center gap-8">
          <a href={base} class="text-slate-400 hover:text-white transition-colors text-sm font-medium tracking-wide">HOME</a>
          <a href={`${base}services`} class="text-slate-400 hover:text-white transition-colors text-sm font-medium tracking-wide">SERVICES</a>
          <a href={`${base}about`} class="text-slate-400 hover:text-white transition-colors text-sm font-medium tracking-wide">ABOUT</a>
          <a href={`${base}news`} class="text-slate-400 hover:text-white transition-colors text-sm font-medium tracking-wide">NEWS</a>
          <a href={`${base}recruit`} class="text-slate-400 hover:text-white transition-colors text-sm font-medium tracking-wide">RECRUIT</a>
          <a href={`${base}contact`} class="ml-2 px-5 py-2 rounded-full text-sm font-medium text-white hero-gradient hover:opacity-90 transition-opacity">
            CONTACT
          </a>
        </nav>

        <!-- Mobile Menu Button -->
        <button id="menu-btn" class="md:hidden text-slate-400 hover:text-white transition-colors" aria-label="メニュー">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>

      <!-- Mobile Menu -->
      <div id="mobile-menu" class="hidden md:hidden glass border-t border-white/5">
        <nav class="max-w-7xl mx-auto px-6 py-4 flex flex-col gap-4">
          <a href={base} class="text-slate-300 hover:text-white transition-colors py-2 text-sm font-medium">HOME</a>
          <a href={`${base}services`} class="text-slate-300 hover:text-white transition-colors py-2 text-sm font-medium">SERVICES</a>
          <a href={`${base}about`} class="text-slate-300 hover:text-white transition-colors py-2 text-sm font-medium">ABOUT</a>
          <a href={`${base}news`} class="text-slate-300 hover:text-white transition-colors py-2 text-sm font-medium">NEWS</a>
          <a href={`${base}recruit`} class="text-slate-300 hover:text-white transition-colors py-2 text-sm font-medium">RECRUIT</a>
          <a href={`${base}contact`} class="text-slate-300 hover:text-white transition-colors py-2 text-sm font-medium">CONTACT</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-white/5 bg-[#05050f]">
      <div class="max-w-7xl mx-auto px-6 py-16">

        <!-- 3カラム: SERVICES | ロゴ | LINKS -->
        <div class="flex flex-col md:flex-row items-center md:items-start justify-between gap-12 mb-12">

          <!-- SERVICES -->
          <div class="text-center md:text-left md:w-1/4">
            <h4 class="text-white font-semibold mb-5 text-xs tracking-widest">SERVICES</h4>
            <ul class="space-y-3 text-slate-500 text-sm">
              <li><a href={`${base}services/ai`} class="hover:text-sky-400 transition-colors">AI構築・コンサルティング</a></li>
              <li><a href={`${base}services/video`} class="hover:text-sky-400 transition-colors">動画制作</a></li>
              <li><a href={`${base}services/drone`} class="hover:text-sky-400 transition-colors">空中・水中ドローン撮影</a></li>
              <li><a href={`${base}services/freediving`} class="hover:text-sky-400 transition-colors">フリーダイビング講習</a></li>
            </ul>
          </div>

          <!-- 中央ロゴ -->
          <div class="flex flex-col items-center md:w-1/2 order-3 md:order-2">
            <a href={base} class="group">
              <img src={`${base}logo.png`} alt="OnO International" class="h-44 w-44 -mb-8" />
            </a>
            <a href={base} class="text-white font-bold text-2xl tracking-wide mb-2">OnO <span class="gradient-text">INTERNATIONAL</span></a>
            <p class="text-slate-600 text-xs">お店の常識を、AIで塗り替える。</p>
          </div>

          <!-- LINKS -->
          <div class="text-center md:text-right md:w-1/4 order-2 md:order-3">
            <h4 class="text-white font-semibold mb-5 text-xs tracking-widest">LINKS</h4>
            <ul class="space-y-3 text-slate-500 text-sm">
              <li><a href={`${base}about`} class="hover:text-sky-400 transition-colors">会社概要</a></li>
              <li><a href={`${base}news`} class="hover:text-sky-400 transition-colors">News & Blog</a></li>
              <li><a href={`${base}recruit`} class="hover:text-sky-400 transition-colors">採用情報</a></li>
              <li><a href={`${base}contact`} class="hover:text-sky-400 transition-colors">お問い合わせ</a></li>
            </ul>
          </div>

        </div>

        <div class="border-t border-white/5 pt-6 text-center text-slate-600 text-xs">
          © 2011 OnO INTERNATIONAL. All rights reserved.
        </div>
      </div>
    </footer>

    <script>
      // Header scroll effect
      const header = document.getElementById('header');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
          header?.classList.add('glass');
          header?.classList.add('border-b', 'border-white/5');
        } else {
          header?.classList.remove('glass', 'border-b', 'border-white/5');
        }
      });

      // Mobile menu
      const menuBtn = document.getElementById('menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      menuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
