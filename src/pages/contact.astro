---
import Layout from '../layouts/Layout.astro';
---

<Layout title="CONTACT" description="OnO INTERNATIONALへのお問い合わせ。動画制作・AI・フリーダイビング・水中映像についてお気軽にご相談ください。">
  <section class="pt-40 pb-24 px-6">
    <div class="max-w-2xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-14">
        <p class="text-sky-400 text-sm font-medium tracking-widest mb-4">CONTACT</p>
        <h1 class="text-5xl md:text-6xl font-black text-white mb-4">お問い合わせ</h1>
        <p class="text-slate-400 leading-relaxed">
          サービスのご相談・お見積りはお気軽にどうぞ。<br/>
          通常2営業日以内にご返信いたします。
        </p>
      </div>

      <!-- Form -->
      <div class="glass rounded-3xl p-8 md:p-10 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-48 h-48 bg-sky-500/5 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-purple-500/5 rounded-full blur-3xl"></div>

        <form id="contact-form" class="relative z-10 space-y-6">

          <!-- Name -->
          <div>
            <label class="block text-slate-300 text-sm font-medium mb-2">
              お名前 <span class="text-sky-400">*</span>
            </label>
            <input
              type="text"
              name="name"
              required
              placeholder="山田 太郎"
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-slate-600 focus:outline-none focus:border-sky-500/50 transition-all text-sm"
            />
          </div>

          <!-- Company -->
          <div>
            <label class="block text-slate-300 text-sm font-medium mb-2">会社名・屋号</label>
            <input
              type="text"
              name="company"
              placeholder="株式会社〇〇"
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-slate-600 focus:outline-none focus:border-sky-500/50 transition-all text-sm"
            />
          </div>

          <!-- Email -->
          <div>
            <label class="block text-slate-300 text-sm font-medium mb-2">
              メールアドレス <span class="text-sky-400">*</span>
            </label>
            <input
              type="email"
              name="email"
              required
              placeholder="your@email.com"
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-slate-600 focus:outline-none focus:border-sky-500/50 transition-all text-sm"
            />
          </div>

          <!-- Service -->
          <div>
            <label class="block text-slate-300 text-sm font-medium mb-2">
              ご相談内容 <span class="text-sky-400">*</span>
            </label>
            <select
              name="service"
              required
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-sky-500/50 transition-all text-sm appearance-none cursor-pointer"
            >
              <option value="" disabled selected class="bg-[#0d0d20]">選択してください</option>
              <option value="動画制作" class="bg-[#0d0d20]">動画制作</option>
              <option value="AI構築・コンサルティング" class="bg-[#0d0d20]">AI構築・コンサルティング</option>
              <option value="フリーダイビング講習" class="bg-[#0d0d20]">フリーダイビング講習</option>
              <option value="水中映像・水中ドローン" class="bg-[#0d0d20]">水中映像・水中ドローン</option>
              <option value="その他" class="bg-[#0d0d20]">その他</option>
            </select>
          </div>

          <!-- Message -->
          <div>
            <label class="block text-slate-300 text-sm font-medium mb-2">
              メッセージ <span class="text-sky-400">*</span>
            </label>
            <textarea
              name="message"
              required
              rows="5"
              placeholder="ご相談内容をお聞かせください..."
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-slate-600 focus:outline-none focus:border-sky-500/50 transition-all text-sm resize-none"
            ></textarea>
          </div>

          <!-- Status message -->
          <div id="form-status" class="hidden text-sm text-center py-3 rounded-xl"></div>

          <!-- Submit -->
          <button
            id="submit-btn"
            type="submit"
            class="w-full py-4 rounded-xl hero-gradient text-white font-bold text-sm hover:opacity-90 transition-all hover:scale-[1.01] shadow-lg shadow-sky-500/20"
          >
            送信する →
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script>
  import emailjs from '@emailjs/browser';

  const SERVICE_ID  = 'service_56n0uhu';
  const TEMPLATE_ID = 'template_03s1ucq';
  const PUBLIC_KEY  = 'Yfg5GlBJPdfw3ZvZY';

  // v4系の初期化方法
  emailjs.init({ publicKey: PUBLIC_KEY });

  const form      = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const statusDiv = document.getElementById('form-status') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    submitBtn.disabled = true;
    submitBtn.textContent = '送信中...';
    statusDiv.className = 'hidden';

    // フォームデータを明示的に取得して送信
    const formData = new FormData(form);
    const templateParams = {
      name:    formData.get('name')    as string,
      company: formData.get('company') as string,
      email:   formData.get('email')   as string,
      service: formData.get('service') as string,
      message: formData.get('message') as string,
    };

    try {
      await emailjs.send(SERVICE_ID, TEMPLATE_ID, templateParams);

      statusDiv.textContent = '✅ 送信が完了しました！2営業日以内にご返信いたします。';
      statusDiv.className = 'text-sm text-center py-3 rounded-xl bg-green-500/10 text-green-400 border border-green-500/20';
      form.reset();
    } catch (err: any) {
      const msg = err?.text || err?.message || JSON.stringify(err);
      statusDiv.textContent = `❌ 送信エラー: ${msg}`;
      statusDiv.className = 'text-sm text-center py-3 rounded-xl bg-red-500/10 text-red-400 border border-red-500/20';
      console.error('EmailJS error:', err);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = '送信する →';
    }
  });
</script>
