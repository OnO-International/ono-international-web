---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog').catch(() => []);
const latestPosts = posts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const base = import.meta.env.BASE_URL;

const services = [
  {
    icon: '🤖',
    title: 'AI構築・コンサルティング',
    desc: '飲食・美容・小売店向けのAI活用支援。集客・接客・売上管理を自動化し、お店の常識を塗り替えます。',
    lpHref: `${import.meta.env.BASE_URL}services/ai`,
    contactHref: `${import.meta.env.BASE_URL}contact`,
    color: 'from-purple-500 to-violet-400',
  },
  {
    icon: '🎬',
    title: '動画制作',
    desc: 'プロモーション動画からSNSコンテンツまで、伝わる映像でブランドの魅力を最大化します。',
    lpHref: `${import.meta.env.BASE_URL}services/video`,
    contactHref: `${import.meta.env.BASE_URL}contact`,
    color: 'from-sky-500 to-cyan-400',
  },
  {
    icon: '🚁',
    title: '空中・水中ドローン撮影',
    desc: '空中ドローンによるダイナミックな空撮と、水中ドローンによる幻想的な映像。唯一無二のコンテンツを届けます。',
    lpHref: `${import.meta.env.BASE_URL}services/drone`,
    contactHref: `${import.meta.env.BASE_URL}contact`,
    color: 'from-blue-500 to-sky-400',
  },
  {
    icon: '🤿',
    title: 'フリーダイビング講習',
    desc: '安全で楽しいフリーダイビングの世界へ。初心者から上級者まで、法人福利厚生としても対応。',
    lpHref: `${import.meta.env.BASE_URL}services/freediving`,
    contactHref: `${import.meta.env.BASE_URL}contact`,
    color: 'from-teal-500 to-emerald-400',
  },
];
---

<Layout title="HOME">

  <!-- 固定背景動画 -->
  <div class="fixed inset-0 overflow-hidden" style="z-index:-1">
    <iframe
      src="https://www.youtube.com/embed/h1cbDz1J8aQ?autoplay=1&mute=1&loop=1&controls=0&showinfo=0&rel=0&iv_load_mode=3&modestbranding=1&playlist=h1cbDz1J8aQ&playsinline=1"
      allow="autoplay; encrypted-media"
      style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) scale(1.5);width:100vw;height:56.25vw;min-height:100vh;min-width:177.78vh;border:none;pointer-events:none;"
    ></iframe>
  </div>

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-[#05050f]">

    <!-- YouTube背景動画 -->
    <div class="absolute inset-0 z-0 overflow-hidden">
      <iframe
        id="yt-bg"
        src="https://www.youtube.com/embed/xWVsR2HLsZc?autoplay=1&mute=1&loop=1&controls=0&showinfo=0&rel=0&iv_load_mode=3&modestbranding=1&playlist=xWVsR2HLsZc&playsinline=1"
        allow="autoplay; encrypted-media"
        allowfullscreen
        style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) scale(1.5);width:100vw;height:56.25vw;min-height:100vh;min-width:177.78vh;border:none;pointer-events:none;"
      ></iframe>
      <!-- 暗めのオーバーレイ：動画の上に文字を読みやすくする -->
      <div class="absolute inset-0 bg-[#05050f]/70"></div>
      <!-- グラデーションオーバーレイ（下部をなじませる） -->
      <div class="absolute inset-0 bg-gradient-to-b from-[#05050f]/30 via-transparent to-[#05050f]"></div>
    </div>

    <div class="relative z-10 w-full max-w-5xl mx-auto px-6 text-center pt-24">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass text-xs text-sky-400 font-medium mb-8 border border-sky-500/20">
        <span class="w-2 h-2 rounded-full bg-sky-400 animate-pulse"></span>
        飲食・美容・小売店のためのAIソリューション
      </div>

      <h1 class="text-5xl md:text-7xl lg:text-8xl font-black mb-6 leading-tight tracking-tight text-center">
        <span class="block text-white">お店の常識を</span>
        <span class="block"><span class="gradient-text">AIで塗り替える</span></span>
      </h1>

      <p class="text-slate-400 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        集客・接客・売上管理——全部、変えられます。<br class="hidden md:block"/>
        OnO INTERNATIONALがあなたのお店の次の一手を、一緒に考えます。
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={`${base}services`} class="px-8 py-4 rounded-full hero-gradient text-white font-semibold text-sm hover:opacity-90 transition-all hover:scale-105 shadow-lg shadow-sky-500/20">
          サービスを見る →
        </a>
        <a href={`${base}contact`} class="px-8 py-4 rounded-full glass text-slate-300 font-semibold text-sm hover:text-white transition-all border border-white/10 hover:border-white/20">
          お問い合わせ
        </a>
      </div>

      <div class="flex flex-col items-center gap-1 mt-8 text-slate-500 text-xs tracking-widest">
        <span>SCROLL</span>
        <div class="scroll-arrow">
          <svg width="13" height="13" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="scroll-arrow" style="opacity:0.6">
          <svg width="13" height="13" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="scroll-arrow" style="opacity:0.3">
          <svg width="13" height="13" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="py-12 px-6 bg-[#05050f]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-sky-400 text-sm font-medium tracking-widest mb-3">SERVICES</p>
        <h2 class="text-4xl md:text-5xl font-black text-white mb-4">私たちにできること</h2>
        <p class="text-slate-500 max-w-xl mx-auto">テクノロジーとクリエイティビティを融合させ、あなたのビジネスに新しい価値を提供します。</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {services.map((s) => (
          <div class="gradient-border rounded-2xl p-8 bg-[#0d0d20] flex flex-col">
            <div class={`w-14 h-14 rounded-xl bg-gradient-to-br ${s.color} flex items-center justify-center text-2xl mb-6`}>
              {s.icon}
            </div>
            <h3 class="text-white text-xl font-bold mb-3">{s.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed flex-1">{s.desc}</p>
            <div class="mt-6 flex gap-3">
              <a href={s.lpHref} class="flex-1 flex items-center justify-center px-4 py-2.5 rounded-full hero-gradient text-white text-xs font-semibold hover:opacity-90 transition-all hover:scale-105">
                詳しく見る →
              </a>
              <a href={s.contactHref} class="flex-1 flex items-center justify-center text-center px-4 py-2.5 rounded-full glass text-slate-300 text-xs font-medium hover:text-white transition-all border border-white/10 hover:border-white/20">
                このサービスを相談する
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="py-12 px-6 bg-[#05050f]">
    <div class="max-w-7xl mx-auto">
      <div class="glass rounded-3xl p-10 md:p-16 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-purple-500/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-sky-500/10 rounded-full blur-3xl"></div>
        <div class="relative z-10 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <p class="text-sky-400 text-sm font-medium tracking-widest mb-3">ABOUT US</p>
            <h2 class="text-4xl md:text-5xl font-black text-white mb-6 leading-tight">
              AIと映像で、<br/><span class="gradient-text">新しい体験</span>を。
            </h2>
            <p class="text-slate-400 leading-relaxed mb-4">
              OnO INTERNATIONALは、動画制作とAI構築を軸に企業さまをコンサルティングする会社です。
            </p>
            <p class="text-slate-400 leading-relaxed mb-8">
              最新技術と深海の静けさが交わる場所で、私たちはあなたのビジョンを形にします。地上の映像から水中の世界まで、唯一無二のコンテンツを届けます。
            </p>
            <a href={`${base}services`} class="inline-flex items-center gap-2 text-sky-400 font-medium hover:gap-3 transition-all">
              サービス一覧 →
            </a>
          </div>
          <div class="grid grid-cols-2 gap-4">
            {[
              { num: '100+', label: 'プロジェクト実績' },
              { num: 'AI', label: '最新技術導入' },
              { num: '30m+', label: '水中撮影深度' },
              { num: '∞', label: 'クリエイティビティ' },
            ].map((stat) => (
              <div class="bg-white/5 rounded-2xl p-6 text-center">
                <div class="gradient-text text-3xl font-black mb-2">{stat.num}</div>
                <div class="text-slate-500 text-xs">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VIDEO WINDOW（透明の窓：固定背景動画が見える） -->
  <div class="relative h-[50vh]">
    <div class="absolute inset-0 bg-gradient-to-b from-[#05050f] via-transparent to-[#05050f] pointer-events-none"></div>
  </div>

  <!-- NEWS -->
  {latestPosts.length > 0 && (
    <section class="py-12 px-6 bg-[#05050f]">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-end justify-between mb-12">
          <div>
            <p class="text-sky-400 text-sm font-medium tracking-widest mb-3">NEWS & BLOG</p>
            <h2 class="text-4xl font-black text-white">最新情報</h2>
          </div>
          <a href={`${base}news`} class="text-sky-400 text-sm font-medium hover:text-sky-300 transition-colors">すべて見る →</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {latestPosts.map((post) => (
            <a href={`${base}news/${post.id}`} class="group gradient-border rounded-2xl bg-[#0d0d20] overflow-hidden hover:scale-[1.02] transition-all duration-300 block">
              <div class="p-6">
                <div class="flex items-center gap-3 mb-4">
                  <span class="text-xs text-sky-400 bg-sky-500/10 px-3 py-1 rounded-full">{post.data.category || 'NEWS'}</span>
                  <span class="text-xs text-slate-600">{new Date(post.data.date).toLocaleDateString('ja-JP')}</span>
                </div>
                <h3 class="text-white font-bold mb-2 group-hover:text-sky-400 transition-colors line-clamp-2">{post.data.title}</h3>
                <p class="text-slate-500 text-sm line-clamp-3">{post.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-12 px-6 bg-[#05050f]">
    <div class="max-w-4xl mx-auto text-center">
      <div class="relative rounded-3xl overflow-hidden">
        <div class="absolute inset-0 hero-gradient opacity-10"></div>
        <div class="absolute inset-0 border border-white/10 rounded-3xl pointer-events-none"></div>
        <div class="relative z-10 p-8 md:p-16">
          <h2 class="text-2xl md:text-5xl font-black text-white mb-4">
            プロジェクトを<br/><span class="gradient-text">一緒に始めましょう</span>
          </h2>
          <p class="text-slate-400 mb-10 max-w-xl mx-auto">
            お気軽にお問い合わせください。あなたのビジョンを形にするお手伝いをします。
          </p>
          <a href={`${base}contact`} class="inline-flex px-10 py-4 rounded-full hero-gradient text-white font-bold hover:opacity-90 transition-all hover:scale-105 shadow-xl shadow-sky-500/20">
            無料相談はこちら →
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
