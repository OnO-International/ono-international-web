---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

const connections = [
  { a: '男', b: '女' },
  { a: '日本', b: '韓国' },
  { a: '人', b: '人' },
  { a: '世界', b: '世界' },
];
---

<Layout
  title="会社概要"
  description="OnO INTERNATIONALは、人と人、国と国、価値と価値をつなぐことを使命とする企業です。代表・小野秀太が韓国での映像制作・起業経験を経て、日本を拠点に国境を越えたビジネス活動を展開しています。"
>

  <!-- Hero -->
  <section class="relative pt-32 pb-24 px-6 overflow-hidden">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-1/4 left-1/3 w-[500px] h-[500px] rounded-full bg-sky-500/5 blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-80 h-80 rounded-full bg-purple-500/8 blur-3xl"></div>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto flex flex-col items-center text-center">
      <p class="text-sky-400 text-sm font-medium tracking-widest mb-8">ABOUT US</p>

      <!-- ロゴ大きく表示 -->
      <div class="mb-4 overflow-hidden w-[480px] md:w-[600px] h-[280px] md:h-[350px]">
        <img
          src={`${base}logo.png`}
          alt="OnO International"
          class="w-full h-full object-cover object-center"
        />
      </div>

      <h1 class="text-5xl md:text-6xl font-black text-white mb-6 leading-tight self-stretch text-center">　O<span class="gradient-text">と</span>OをN<span class="gradient-text">で</span>結ぶ。</h1>
      <p class="text-slate-400 text-lg max-w-2xl leading-relaxed">
        OnO INTERNATIONALは、人と人、国と国、<br class="hidden md:block"/>
        価値と価値をつなぐことを使命とする企業です。
      </p>
    </div>
  </section>

  <!-- Name の意味 -->
  <section class="pb-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="glass rounded-3xl p-10 md:p-16 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-72 h-72 bg-sky-500/8 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-72 h-72 bg-purple-500/8 rounded-full blur-3xl"></div>
        <div class="relative z-10">
          <p class="text-sky-400 text-sm font-medium tracking-widest mb-4 text-center">THE NAME</p>
          <h2 class="text-3xl md:text-4xl font-black text-white mb-6 text-center">
            OnOという名前の意味
          </h2>
          <p class="text-slate-400 text-center max-w-2xl mx-auto mb-12 leading-relaxed">
            OとOをNで結ぶ——それがOnOという名前に込められた想いです。
          </p>

          <!-- O n O ビジュアル -->
          <div class="flex items-center justify-center gap-4 mb-14">
            <div class="w-20 h-20 rounded-full flex items-center justify-center text-white font-black text-3xl"
              style="background: radial-gradient(circle at 35% 30%, #ff6e82, #c41040)">O</div>
            <div class="flex flex-col items-center">
              <span class="text-slate-400 text-5xl font-black" style="font-style: italic;">n</span>
            </div>
            <div class="w-20 h-20 rounded-full flex items-center justify-center text-white font-black text-3xl"
              style="background: radial-gradient(circle at 40% 30%, #8898d8, #2432a0)">O</div>
          </div>

          <!-- つながり一覧 -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            {connections.map((c) => (
              <div class="bg-white/5 rounded-2xl p-5 text-center border border-white/5">
                <div class="flex items-center justify-center gap-2 mb-1">
                  <span class="text-white font-bold text-lg">{c.a}</span>
                  <span class="text-sky-400 text-sm">と</span>
                  <span class="text-white font-bold text-lg">{c.b}</span>
                </div>
                <div class="text-slate-500 text-xs mt-1">を結ぶ</div>
              </div>
            ))}
          </div>

          <p class="text-slate-400 text-center mt-10 leading-relaxed">
            あらゆる価値をつなぎ、<span class="text-white font-semibold">幸せと幸せを結ぶ架け橋</span>となること。<br/>
            それがOnO INTERNATIONALの存在意義です。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- One & Only -->
  <section class="pb-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- Philosophy -->
        <div class="gradient-border rounded-3xl bg-[#0d0d20] p-10">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-purple-500 to-violet-400 flex items-center justify-center text-2xl mb-6">💎</div>
          <span class="text-xs font-medium px-3 py-1 rounded-full text-purple-400 bg-purple-500/10 mb-4 inline-block">PHILOSOPHY</span>
          <h3 class="text-2xl font-black text-white mb-4">One &amp; Only</h3>
          <p class="text-slate-400 leading-relaxed">
            私たちは、すべての人が唯一無二の存在であるという「One & Only」の思想を大切にしています。
            国籍や文化、業種や規模に関わらず、あなたのビジネスには他にはない固有の価値があります。
            その価値を最大限に引き出すことが、私たちの使命です。
          </p>
        </div>

        <!-- Vision -->
        <div class="gradient-border rounded-3xl bg-[#0d0d20] p-10">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-sky-500 to-cyan-400 flex items-center justify-center text-2xl mb-6">🌍</div>
          <span class="text-xs font-medium px-3 py-1 rounded-full text-sky-400 bg-sky-500/10 mb-4 inline-block">VISION</span>
          <h3 class="text-2xl font-black text-white mb-4">世界をつなぐ</h3>
          <p class="text-slate-400 leading-relaxed">
            国境や文化の違いを超え、世界中の人々がそれぞれの幸せを実現できる社会をつくる。
            テクノロジーと映像の力で、あらゆる垣根をなくし、
            すべての人が輝けるビジネス環境を創造し続けます。
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- 代表プロフィール -->
  <section class="pb-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-sky-400 text-sm font-medium tracking-widest mb-3">FOUNDER</p>
        <h2 class="text-4xl font-black text-white">代表者紹介</h2>
      </div>

      <div class="gradient-border rounded-3xl bg-[#0d0d20] p-10 md:p-14">
        <div class="flex flex-col md:flex-row gap-10 items-start">

          <!-- アイコン -->
          <div class="flex-shrink-0 mx-auto md:mx-0">
            <div class="w-32 h-32 rounded-3xl flex items-center justify-center text-6xl"
              style="background: radial-gradient(135deg at 35% 30%, #ff6e82 0%, #c41040 50%, #2432a0 100%)">
              🧑‍💼
            </div>
            <div class="text-center mt-4">
              <p class="text-white font-bold text-lg">小野 秀太</p>
              <p class="text-sky-400 text-sm">Shuta Ono</p>
              <p class="text-slate-500 text-xs mt-1">代表</p>
            </div>
          </div>

          <!-- テキスト -->
          <div class="flex-1">
            <div class="space-y-5 text-slate-400 leading-relaxed">
              <p>
                韓国の大学を卒業後、韓国の映像プロダクションにて映画制作・撮影などの現場を経験。
                その後、韓国で起業し、<span class="text-white">10年以上にわたり経営に携わってきました</span>。
              </p>
              <p>
                現在は日本を拠点に、国境を越えたビジネス活動を展開。
                日韓の文化とビジネスを深く理解した視点から、
                <span class="text-white">AIの活用・映像制作・ドローン撮影</span>を通じて、
                クライアントのビジネスに新しい価値を届けています。
              </p>
              <p>
                「OnO」という社名に込めた想い通り、
                <span class="text-white">あらゆる境界を越えて人と価値をつなぐこと</span>を
                ライフワークとしています。
              </p>
            </div>

            <!-- キャリアタイムライン -->
            <div class="mt-8 space-y-4">
              <div class="flex gap-4 items-start">
                <div class="w-2 h-2 rounded-full bg-sky-400 mt-2 flex-shrink-0"></div>
                <div>
                  <p class="text-white text-sm font-semibold">韓国・大学卒業</p>
                  <p class="text-slate-500 text-xs">韓国の映像プロダクションに入社</p>
                </div>
              </div>
              <div class="flex gap-4 items-start">
                <div class="w-2 h-2 rounded-full bg-purple-400 mt-2 flex-shrink-0"></div>
                <div>
                  <p class="text-white text-sm font-semibold">映画制作・撮影の現場を経験</p>
                  <p class="text-slate-500 text-xs">韓国映像プロダクションにて実務を習得</p>
                </div>
              </div>
              <div class="flex gap-4 items-start">
                <div class="w-2 h-2 rounded-full bg-teal-400 mt-2 flex-shrink-0"></div>
                <div>
                  <p class="text-white text-sm font-semibold">韓国で起業</p>
                  <p class="text-slate-500 text-xs">10年以上にわたり経営に携わる</p>
                </div>
              </div>
              <div class="flex gap-4 items-start">
                <div class="w-2 h-2 rounded-full bg-gradient-to-r from-sky-400 to-purple-400 mt-2 flex-shrink-0"></div>
                <div>
                  <p class="text-white text-sm font-semibold">OnO International 設立</p>
                  <p class="text-slate-500 text-xs">日本を拠点に国境を越えたビジネス活動を展開</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 会社概要テーブル -->
  <section class="pb-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-sky-400 text-sm font-medium tracking-widest mb-3">COMPANY INFO</p>
        <h2 class="text-4xl font-black text-white">会社情報</h2>
      </div>
      <div class="gradient-border rounded-3xl bg-[#0d0d20] overflow-hidden">
        <table class="w-full">
          <tbody>
            {[
              { label: '会社名', value: 'OnO International（オーエヌオー・インターナショナル）' },
              { label: '代表者', value: '小野 秀太（Shuta Ono）' },
              { label: '所在地', value: '福岡県福岡市南区長丘４−６−３' },
              { label: '事業内容', value: 'AI構築・コンサルティング／動画制作／空中・水中ドローン撮影／フリーダイビング講習' },
              { label: 'ミッション', value: '人と人、国と国、価値と価値をつなぐ' },
              { label: 'ビジョン', value: '国境や文化の違いを超え、世界中の人々がそれぞれの幸せを実現できる社会をつくる' },
            ].map((row, i) => (
              <tr class={i !== 5 ? 'border-b border-white/5' : ''}>
                <td class="px-8 py-5 text-slate-500 text-sm font-medium w-1/3 align-top">{row.label}</td>
                <td class="px-8 py-5 text-slate-300 text-sm leading-relaxed">{row.value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="pb-24 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <div class="relative rounded-3xl overflow-hidden">
        <div class="absolute inset-0 hero-gradient opacity-10"></div>
        <div class="absolute inset-0 border border-white/10 rounded-3xl pointer-events-none"></div>
        <div class="relative z-10 p-16">
          <h2 class="text-4xl md:text-5xl font-black text-white mb-4">
            一緒に、<br/><span class="gradient-text">新しい価値を創ろう</span>。
          </h2>
          <p class="text-slate-400 mb-10 max-w-xl mx-auto">
            お店のAI活用から映像制作まで、あなたのビジネスに合った最適な提案をします。
            まずはお気軽にご相談ください。
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`${base}contact`} class="inline-flex px-10 py-4 rounded-full hero-gradient text-white font-bold hover:opacity-90 transition-all hover:scale-105 shadow-xl shadow-sky-500/20">
              お問い合わせ →
            </a>
            <a href={`${base}recruit`} class="inline-flex px-10 py-4 rounded-full glass text-slate-300 font-semibold hover:text-white transition-all border border-white/10 hover:border-white/20">
              採用情報を見る
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
