---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="空中・水中ドローン撮影" description="空中ドローン4K空撮・水中ドローン撮影。誰も見たことのないアングルで、あなたのコンテンツを圧倒的に差別化します。OnO INTERNATIONAL。">

  <!-- Hero -->
  <section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute top-1/4 right-1/3 w-[600px] h-[600px] rounded-full bg-blue-600/15 blur-[120px]"></div>
      <div class="absolute bottom-1/3 left-1/4 w-[400px] h-[400px] rounded-full bg-sky-400/10 blur-[100px]"></div>
      <div class="absolute top-1/2 left-1/2 w-[300px] h-[300px] rounded-full bg-teal-500/8 blur-[80px]"></div>
    </div>
    <div class="relative z-10 max-w-5xl mx-auto px-6 text-center pt-32 pb-20">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass text-xs text-blue-400 font-medium mb-8 border border-blue-500/20">
        <span class="w-2 h-2 rounded-full bg-blue-400 animate-pulse"></span>
        空中・水中ドローン撮影
      </div>
      <h1 class="text-5xl md:text-7xl font-black mb-6 leading-tight">
        <span class="text-white">誰も見たことのない</span><br/>
        <span class="gradient-text">アングル</span><span class="text-white">を届ける。</span>
      </h1>
      <p class="text-slate-400 text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        空の上から、海の底まで。<br class="hidden md:block"/>
        ドローンが切り拓く映像の新世界で、あなたのコンテンツを圧倒的に差別化します。
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={`${base}contact`} class="px-8 py-4 rounded-full hero-gradient text-white font-bold text-sm hover:opacity-90 transition-all hover:scale-105 shadow-lg shadow-sky-500/20">
          撮影を相談する →
        </a>
        <a href="#services" class="px-8 py-4 rounded-full glass text-slate-300 font-semibold text-sm hover:text-white transition-all border border-white/10">
          撮影内容を見る
        </a>
      </div>
    </div>
  </section>

  <!-- 2サービス概要 -->
  <section id="services" class="py-20 px-6">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">

      <!-- 空中ドローン -->
      <div class="gradient-border rounded-3xl bg-[#0d0d20] p-10">
        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-sky-500 to-blue-600 flex items-center justify-center text-4xl mb-6">🚁</div>
        <h2 class="text-3xl font-black text-white mb-4">空中ドローン撮影</h2>
        <p class="text-slate-400 leading-relaxed mb-6">
          4K・8K対応のプロ機材を使った空撮で、地上からでは絶対に撮れない壮大な景観を映像に。
          建設・不動産・観光・イベント・ウェディングなど幅広く対応します。
        </p>
        <ul class="space-y-3">
          {[
            '4K/8K高解像度空撮',
            'ビル・施設・土地の全景撮影',
            '観光地・景勝地の空撮',
            'イベント・コンサート上空撮影',
            'ウェディング・記念日撮影',
            '不動産・建設現場の定点記録',
            '農業・林業・インフラ点検',
          ].map((f) => (
            <li class="flex items-center gap-3 text-slate-300 text-sm">
              <span class="w-1.5 h-1.5 rounded-full bg-sky-400 flex-shrink-0"></span>
              {f}
            </li>
          ))}
        </ul>
      </div>

      <!-- 水中ドローン -->
      <div class="gradient-border rounded-3xl bg-[#0d0d20] p-10">
        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-teal-500 to-blue-600 flex items-center justify-center text-4xl mb-6">🌊</div>
        <h2 class="text-3xl font-black text-white mb-4">水中ドローン撮影</h2>
        <p class="text-slate-400 leading-relaxed mb-6">
          水中ドローンと専用水中カメラを駆使し、海・プール・ダム・川など水中の幻想的な世界を映像化。
          フリーダイビングチーム「Team Dragon」との連携で深度30m以上の撮影も可能。
        </p>
        <ul class="space-y-3">
          {[
            '水中ドローン撮影（海・プール・ダム）',
            '水中カメラによる高画質撮影',
            '深度30m以上の水中映像制作',
            '水面〜水中のシームレス映像',
            'マリンスポーツ・競技撮影',
            'サンゴ礁・生態系記録映像',
            '水中建造物・インフラ点検',
          ].map((f) => (
            <li class="flex items-center gap-3 text-slate-300 text-sm">
              <span class="w-1.5 h-1.5 rounded-full bg-teal-400 flex-shrink-0"></span>
              {f}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- 活用シーン -->
  <section class="py-20 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-blue-400 text-sm font-medium tracking-widest mb-3">USE CASES</p>
        <h2 class="text-4xl font-black text-white mb-4">こんな場面で使われています</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { icon: '🏗️', label: '建設・不動産' },
          { icon: '🌅', label: '観光・旅行PR' },
          { icon: '💒', label: 'ウェディング' },
          { icon: '🎪', label: 'イベント・フェス' },
          { icon: '🎬', label: '映画・TV制作' },
          { icon: '🌊', label: 'マリンスポーツ' },
          { icon: '🐠', label: '海洋調査・記録' },
          { icon: '🏖️', label: 'リゾート・ホテル' },
        ].map((item) => (
          <div class="bg-white/5 rounded-2xl p-5 text-center hover:bg-blue-500/10 transition-colors">
            <div class="text-3xl mb-2">{item.icon}</div>
            <p class="text-slate-300 text-xs font-medium">{item.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 空×水中 コンボの強み -->
  <section class="py-20 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="glass rounded-3xl p-10 md:p-14 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-80 h-80 bg-blue-500/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-80 h-80 bg-teal-500/10 rounded-full blur-3xl"></div>
        <div class="relative z-10">
          <div class="text-center mb-10">
            <p class="text-blue-400 text-sm font-medium tracking-widest mb-3">UNIQUE STRENGTH</p>
            <h2 class="text-4xl font-black text-white mb-4">空と海、両方できるのはOnOだけ</h2>
            <p class="text-slate-500 max-w-2xl mx-auto">
              空中ドローンと水中撮影を組み合わせた「水面突入ショット」など、
              他社では真似できない唯一無二の映像表現が可能です。
            </p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {[
              { icon: '🎯', title: '唯一無二のアングル', desc: '空から海へダイブするシームレスな映像は、世界でもごく限られたチームにしか撮れません。' },
              { icon: '⚡', title: 'ワンストップ対応', desc: '撮影・編集・納品まで一貫して対応。複数の業者に頼む手間・コストを省けます。' },
              { icon: '🤿', title: 'フリーダイバーとの連携', desc: 'Team Dragonのフリーダイバーと組むことで、深度30m以上の水中撮影も安全に実現。' },
            ].map((item) => (
              <div class="text-center">
                <div class="text-4xl mb-4">{item.icon}</div>
                <h3 class="text-white font-bold mb-2">{item.title}</h3>
                <p class="text-slate-500 text-sm leading-relaxed">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 撮影の流れ -->
  <section class="py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-blue-400 text-sm font-medium tracking-widest mb-3">PROCESS</p>
        <h2 class="text-4xl font-black text-white">撮影の流れ</h2>
      </div>
      <div class="space-y-6">
        {[
          { step: 'STEP 1', title: 'ヒアリング・ロケハン', desc: '撮影目的・場所・イメージをヒアリングし、必要に応じて事前ロケハンを実施します。' },
          { step: 'STEP 2', title: '撮影プラン・許可申請', desc: '飛行申請（国土交通省）や撮影許可など必要な手続きをすべて代行します。' },
          { step: 'STEP 3', title: '撮影当日', desc: '安全を最優先に、プロのオペレーターが現場を担当。天候に合わせた柔軟な対応も行います。' },
          { step: 'STEP 4', title: '編集・納品', desc: 'カラーグレーディング・BGM・テロップを加えて完成。各プラットフォーム用フォーマットで納品。' },
        ].map((item) => (
          <div class="gradient-border rounded-2xl bg-[#0d0d20] p-8 flex gap-6 items-start">
            <div class="flex-shrink-0">
              <span class="text-xs font-bold px-3 py-1 rounded-full border text-blue-400 border-blue-500/30">{item.step}</span>
            </div>
            <div>
              <h3 class="text-white font-bold text-xl mb-2">{item.title}</h3>
              <p class="text-slate-400 text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <div class="relative rounded-3xl overflow-hidden">
        <div class="absolute inset-0 hero-gradient opacity-10"></div>
        <div class="absolute inset-0 border border-white/10 rounded-3xl pointer-events-none"></div>
        <div class="relative z-10 p-6 md:p-20">
          <h2 class="text-2xl md:text-5xl font-black text-white mb-4">
            空から海へ。<br/><span class="gradient-text">その映像で、<br class="md:hidden"/>世界を驚かせよう。</span>
          </h2>
          <p class="text-slate-400 mb-10 max-w-xl mx-auto">
            撮影場所・内容・予算など、まずはお気軽にご相談ください。<br/>
            航空法申請など面倒な手続きもすべてお任せください。
          </p>
          <a href={`${base}contact`} class="inline-flex px-10 py-4 rounded-full hero-gradient text-white font-bold hover:opacity-90 transition-all hover:scale-105 shadow-xl shadow-sky-500/20">
            撮影を相談する →
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
